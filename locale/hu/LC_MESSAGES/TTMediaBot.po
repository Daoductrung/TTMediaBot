msgstr "Ez a felhasználó nem szerepel az adminisztrátor listán"

#: bot/commands/admin_commands.py:319 bot/commands/admin_commands.py:349
msgid "<Anonymous>"
msgstr "<Anonymous>"

#: bot/commands/admin_commands.py:328
msgid ""
"+/-USERNAME Manages a list of banned users. +USERNAME adds a user. "
"-USERNAME removes it. Without an option shows the list"
msgstr ""
