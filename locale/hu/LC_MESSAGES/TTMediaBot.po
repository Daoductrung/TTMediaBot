#: bot/commands/admin_commands.py:20
msgid ""
"+/-COMMAND Blocks or unblocks commands. +COMMAND adds command to the "
"blocklist. -COMMAND removes from it. Without a command shows the "
"blocklist"
msgstr ""
"+/-PARANCS letiltja vagy feloldja a parancsokat. +PARANCS hozzáadja a "
"parancsot a tiltólistához, a -PARANCS pedig eltávolítja azt. Paraméterek "
"nélkül a tiltólistát mutatja"

