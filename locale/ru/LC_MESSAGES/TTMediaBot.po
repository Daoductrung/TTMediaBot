# --- Search Results Mode (sr/sl/slc) ---
msgid ""
"QUERY Plays tracks found for the query. If no query is given, plays or pauses current track. When search results mode (sr) is active, shows a numbered list instead"
msgstr ""
"ЗАПРОС Воспроизводит треки по запросу. Без запроса — воспроизводит или ставит на паузу. В режиме результатов (sr) показывает нумерованный список"

msgid "Search results:"
msgstr "Результаты поиска:"

msgid "Use 'sl NUMBER' to select a track"
msgstr "Используйте 'sl НОМЕР' для выбора трека"

msgid "Search results mode: ON"
msgstr "Режим результатов поиска: ВКЛЮЧЁН"

msgid "Search results mode: OFF"
msgstr "Режим результатов поиска: ВЫКЛЮЧЕН"

msgid ""
"Toggles search results mode. When active, 'p QUERY' shows a numbered list. Use 'sr on' or 'sr off' to set explicitly. Save permanently with 'sc'"
msgstr ""
"Переключает режим результатов поиска. При включении 'p ЗАПРОС' показывает список. Используйте 'sr on' или 'sr off'. Сохраните постоянно с помощью 'sc'"

msgid ""
"NUMBER Selects and plays result NUMBER from the last search list (requires search results mode to be active)"
msgstr ""
"НОМЕР Выбирает и воспроизводит результат НОМЕР из последнего поиска (требует активного режима результатов)"

msgid "No search results available. Use 'p QUERY' to search first"
msgstr "Нет доступных результатов. Сначала выполните 'p ЗАПРОС'"

msgid "{nickname} selected: {track}"
msgstr "{nickname} выбрал: {track}"

msgid ""
"NUMBER Sets how many results are shown when search results mode is active. Without a number shows current count. Resets to 5 on restart"
msgstr ""
"НОМЕР Задаёт количество результатов в режиме поиска. Без числа показывает текущее значение. Сбрасывается до 5 при перезапуске"

msgid "Search results count: {count}"
msgstr "Количество результатов: {count}"

msgid "Search results count set to {count}"
msgstr "Количество результатов установлено: {count}"

msgid "Invalid count. Please enter a number greater than 0"
msgstr "Неверное значение. Введите число больше 0"

